# 华为云 OCR 配置模板
OCR_PROVIDER=huawei
OCR_USE_MOCK=1

HUAWEI_OCR_ENDPOINT=
HUAWEI_OCR_AK=
HUAWEI_OCR_SK=
HUAWEI_PROJECT_ID=
OCR_API_PATH=/v2/{project_id}/ocr/general-table
OCR_PDF_MAX_PAGES=8
# 未手工传 confirmed_mappings 时，仅自动确认达到该置信度的候选
OCR_AUTO_CONFIRM_MIN_SCORE=0.92

# DeepSeek AI（真实密钥只填写在 backend/.env，不要提交）
AI_PROVIDER=deepseek
# 开箱本地演示使用 Mock；真实 DeepSeek 联调时改为 0 并填写 API Key
AI_USE_MOCK=1
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_CONNECT_TIMEOUT_SECONDS=5
AI_READ_TIMEOUT_SECONDS=30
AI_REQUEST_TIMEOUT_SECONDS=60
# 发送给后端的最近 user/assistant 消息总数上限（必须为完整轮次）
AI_MAX_HISTORY_MESSAGES=20
# AI 无法回答复杂问题时展示的人工客服电话
AI_SUPPORT_PHONE=
# 匿名/登录用户每分钟请求上限
AI_GUEST_RATE_LIMIT_PER_MINUTE=10
AI_AUTH_RATE_LIMIT_PER_MINUTE=30

# 本地公共知识 RAG。先显式执行 `python scripts/rag_sync.py sync`，成功后再开启。
RAG_ENABLED=0
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_EMBEDDING_THREADS=1
RAG_VECTOR_SIZE=512
# 留空时使用 backend/instance/rag/qdrant 的单进程 Qdrant Local。
RAG_QDRANT_URL=
RAG_QDRANT_API_KEY=
# 默认使用 backend/instance/rag；生产环境可取消注释并改为持久化绝对路径。
# RAG_RUNTIME_PATH=instance/rag
RAG_TOP_K=8
RAG_CHAT_CONTEXT_K=4
RAG_ANALYSIS_CONTEXT_K=6
RAG_MIN_SCORE=0.35
RAG_MAX_CONTEXT_CHARS=12000

# 仅运行合成档案 apply 时临时设置；不要提交真实或复用密码。
RAG_DEMO_PASSWORD=

# 本地数据库默认使用 backend/instance/health_system.db，无需配置。
# 如需使用另一个本地 SQLite 文件，可覆盖：
# LOCAL_DATABASE_URL=sqlite:///health_system.db
# 服务器可通过 PostgreSQL 协议连接 GaussDB/openGauss；生产环境优先读取该项：
# DATABASE_URL=opengauss+psycopg2://user:password@127.0.0.1:5432/database
# 上传根目录和对外 URL 前缀；通常保持默认即可
# UPLOAD_DIR=uploads
# UPLOAD_URL_BASE=/uploads
# 项目 production 启动脚本会在缺失时生成至少 32 字符的随机 JWT 密钥；
# 直接调用 Waitress 或使用自定义部署方式时必须显式设置。
# JWT_SECRET_KEY=
# 登录/注册图片验证码有效期，单位：秒
# CAPTCHA_TTL_SECONDS=300
# DEFAULT_ADMIN_USERNAME=admin
# production 首次启动或仍使用 admin123 时，必须设置至少 12 字符的新密码；
# 系统会在首次安全启动时替换旧演示密码。仅监听回环地址的项目启动脚本
# 会启用本机演示模式；开发模式未配置时仍使用 admin123。
# DEFAULT_ADMIN_PASSWORD=
# 仅由本机回环启动脚本临时设置，切勿手工用于对外监听。
# ALLOW_INSECURE_LOCAL_DEMO=0
# DEFAULT_ADMIN_EMAIL=admin@example.com
# 机构图片单张最大字节数（默认 5MB）
# INSTITUTION_IMAGE_MAX_BYTES=5242880
# 高熵邀请码随机字节数
# INVITE_CODE_BYTES=24
