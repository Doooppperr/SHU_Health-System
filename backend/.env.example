# 华为云 OCR 配置模板
OCR_PROVIDER=huawei
OCR_USE_MOCK=1

HUAWEI_OCR_ENDPOINT=
HUAWEI_OCR_AK=
HUAWEI_OCR_SK=
HUAWEI_PROJECT_ID=
OCR_API_PATH=/v2/{project_id}/ocr/general-table

# 数据库配置，开发/演示运行必须显式填写 DATABASE_URL
# 云数据库 GaussDB / openGauss，本地运行时推荐通过 SSH 隧道连接内网库
# DATABASE_URL=opengauss+psycopg2://health_app:your_password@gaussdb-host:8000/health_system?client_encoding=utf8
# TARGET_DATABASE_URL=opengauss+psycopg2://health_app:your_password@gaussdb-host:8000/health_system?client_encoding=utf8
# 只有 GaussDB 内网地址时，可先用 SSH 隧道映射到本机 15432 端口
# DATABASE_URL=opengauss+psycopg2://health_app:your_password@127.0.0.1:15432/health_system?client_encoding=utf8
# TARGET_DATABASE_URL=opengauss+psycopg2://health_app:your_password@127.0.0.1:15432/health_system?client_encoding=utf8
# GaussDB(for MySQL)
# DATABASE_URL=mysql+pymysql://health_app:your_password@gaussdb-host:3306/health_system?charset=utf8mb4
# TARGET_DATABASE_URL=mysql+pymysql://health_app:your_password@gaussdb-host:3306/health_system?charset=utf8mb4
# JWT_SECRET_KEY=
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_ADMIN_EMAIL=admin@example.com
